# ==========================================
# case-study-delabo Root Git Ignore
# ==========================================

# --- Python / Backend ---
backend/venv/
backend/.venv/
**/__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
*.db
*.sqlite

# --- Node.js / Frontend ---
frontend/node_modules/
frontend/dist/
frontend/build/
.npm
npm-debug.log*

# --- Credentials & Secrets ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key

# --- Operating System & IDEs ---
.DS_Store
Thumbs.db
.vscode/
.idea/

# --- Large 3D Models & Extracted Textures ---
# Ignore unoptimized original model and unused compression fallback
frontend/public/models/Hospital-Room-2.glb
frontend/public/models/Hospital-Room-2-draco.glb

# Ignore redundant extracted textures (already packed inside the optimized GLB)
frontend/public/models/textures/
frontend/public/textures/
